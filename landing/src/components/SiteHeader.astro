---
---
<header class="site-header glass-panel">
  <div class="container header-container">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="url(#logo-gradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
        <defs>
          <linearGradient id="logo-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#34d399" />
            <stop offset="100%" stop-color="#059669" />
          </linearGradient>
        </defs>
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
      </svg>
      <span class="logo-text">Crop<span class="text-gradient">CheckUp</span></span>
    </div>
    <nav class="main-nav">
      <a href="#how-it-works" class="nav-link">How It Works</a>
      <a href="#pipeline" class="nav-link">Pipeline</a>
      <a href="#model-output" class="nav-link">Model Output</a>
      <a href="#dataset" class="nav-link">Dataset</a>
    </nav>
    <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" class="btn btn-primary nav-cta" target="_blank" rel="noopener noreferrer">Kaggle Notebook</a>
  </div>
</header>
<style>
  .site-header {
    position: sticky;
    top: 1rem;
    z-index: 100;
    margin: 1rem auto;
    width: calc(100% - 2rem);
    max-width: var(--section-width);
    border-radius: var(--radius-full);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    padding: 0 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .logo-icon {
    width: 28px;
    height: 28px;
    filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.4));
  }

  .main-nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-brand-primary);
    transition: width 0.3s ease;
    border-radius: 2px;
    box-shadow: 0 0 8px var(--color-brand-primary);
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    text-shadow: none;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    font-size: var(--font-size-sm);
  }

  @media (max-width: 768px) {
    .site-header {
      top: 0;
      margin: 0;
      width: 100%;
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
    }
    
    .header-container {
      flex-wrap: wrap;
      height: auto;
      padding: 1rem;
      gap: 1rem;
    }
    
    .main-nav {
      flex: 1 1 100%;
      order: 3;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      gap: 1rem;
      scrollbar-width: none;
    }
    
    .main-nav::-webkit-scrollbar {
      display: none;
    }
  }
</style>
