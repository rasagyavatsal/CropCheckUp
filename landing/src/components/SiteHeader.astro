---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="site-header glass-panel">
  <div class="container header-container">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
      </svg>
      <span class="logo-text">Crop<span class="text-highlight">CheckUp</span></span>
    </div>
    <nav class="main-nav">
      <a href="#how-it-works" class="nav-link">Workflow</a>
      <a href="#pipeline" class="nav-link">Pipeline</a>
      <a href="#model-output" class="nav-link">Output</a>
      <a href="#dataset" class="nav-link">Dataset</a>
      <a href="#limitations" class="nav-link">Limits</a>
    </nav>
    <div class="header-actions">
      <ThemeToggle />
      <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" class="btn btn-primary nav-cta" target="_blank" rel="noopener noreferrer">Kaggle Notebook</a>
    </div>
  </div>
</header>
<style>
  .site-header {
    position: sticky;
    top: 1rem;
    z-index: 100;
    margin: 1rem auto;
    width: calc(100% - 2rem);
    max-width: var(--section-width);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 30px rgba(23, 32, 27, 0.08);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    padding: 0 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .logo-icon {
    width: 28px;
    height: 28px;
    filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.4));
  }

  .main-nav {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .nav-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-brand-primary);
    transition: width 0.3s ease;
    border-radius: 2px;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    text-shadow: none;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    font-size: var(--font-size-sm);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .site-header {
      top: 0;
      margin: 0;
      width: 100%;
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
    }
    
    .header-container {
      flex-wrap: wrap;
      height: auto;
      padding: 1rem;
      gap: 1rem;
    }
    
    .main-nav {
      flex: 1 1 100%;
      order: 3;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      gap: 1rem;
      scrollbar-width: none;
    }
    
    .main-nav::-webkit-scrollbar {
      display: none;
    }
  }
</style>
