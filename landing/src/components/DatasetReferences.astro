---
---
<section id="dataset" class="section">
  <div class="container">
    <div class="section-header text-center">
      <h2>Resources & <span class="text-gradient">Datasets</span></h2>
      <p class="section-subtitle">Explore the data and code powering CropCheckUp.</p>
    </div>
    
    <div class="resources-grid">
      <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" target="_blank" rel="noopener noreferrer" class="resource-card glass-panel">
        <div class="card-bg-glow glow-blue"></div>
        <div class="resource-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        </div>
        <div class="resource-content">
          <h3>Kaggle Notebook</h3>
          <p>Deep dive into the model development workflow, architecture decisions, and experimentation process.</p>
        </div>
        <div class="resource-action">
          <span class="action-text">View Code</span>
          <span class="arrow">→</span>
        </div>
      </a>

      <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" target="_blank" rel="noopener noreferrer" class="resource-card glass-panel">
        <div class="card-bg-glow glow-green"></div>
        <div class="resource-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
        </div>
        <div class="resource-content">
          <h3>CropCheckUp Dataset</h3>
          <p>Access the comprehensive image dataset used for training and validating the crop disease classification model.</p>
        </div>
        <div class="resource-action">
          <span class="action-text">Download Data</span>
          <span class="arrow">→</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--space-3xl);
  }
  
  .section-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-l);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
  }

  .card-bg-glow {
    position: absolute;
    top: -50px;
    right: -50px;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.2;
    transition: opacity 0.4s ease;
  }

  .glow-blue {
    background: #3b82f6;
  }

  .glow-green {
    background: #10b981;
  }

  .resource-card:hover {
    transform: translateY(-10px);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .resource-card:hover .card-bg-glow {
    opacity: 0.5;
  }

  .resource-icon {
    margin-bottom: var(--space-m);
    position: relative;
    z-index: 1;
    color: var(--color-brand-primary);
  }
  
  .glow-blue + .resource-icon {
    color: #3b82f6;
  }

  .resource-content {
    flex: 1;
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-l);
  }

  .resource-content h3 {
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-s);
  }

  .resource-content p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin: 0;
  }

  .resource-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-m);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    z-index: 1;
  }

  .action-text {
    font-weight: 500;
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    transition: color 0.3s ease;
  }

  .arrow {
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  .resource-card:hover .action-text {
    color: var(--color-brand-primary);
  }

  .resource-card:hover .arrow {
    color: var(--color-brand-primary);
    transform: translateX(5px);
  }
</style>
