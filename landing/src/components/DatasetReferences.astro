---
---
<section id="dataset" class="section">
  <div class="container">
    <div class="section-header">
      <p class="section-kicker">Project evidence</p>
      <h2>Resources & <span class="text-highlight">Datasets</span></h2>
      <p class="section-subtitle">The model development workflow is documented in the Kaggle notebook. The dataset used for CropCheckUp experiments and training is available on Kaggle.</p>
    </div>
    
    <div class="resources-grid">
      <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" target="_blank" rel="noopener noreferrer" class="resource-card glass-panel">
        <div class="resource-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        </div>
        <div class="resource-content">
          <h3>Kaggle Notebook</h3>
          <p>Model development workflow and experimentation.</p>
          <ul class="resource-list">
            <li>Training and validation flow</li>
            <li>Model export assumptions</li>
            <li>Notebook-level experiment trace</li>
          </ul>
        </div>
        <div class="resource-action">
          <span class="action-text">View Code</span>
          <span class="arrow">-&gt;</span>
        </div>
      </a>

      <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" target="_blank" rel="noopener noreferrer" class="resource-card glass-panel">
        <div class="resource-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
        </div>
        <div class="resource-content">
          <h3>CropCheckUp Dataset</h3>
          <p>Image dataset used for CropCheckUp experiments and training.</p>
          <ul class="resource-list">
            <li>Crop and condition image labels</li>
            <li>Training data reference</li>
            <li>Dataset source for reproducibility</li>
          </ul>
        </div>
        <div class="resource-action">
          <span class="action-text">Download Data</span>
          <span class="arrow">-&gt;</span>
        </div>
      </a>
    </div>
    
    <div class="dataset-attribution">
      <h3>Source Dataset Attribution</h3>
      <ul>
        <li><strong>PlantVillage:</strong> Licensed under CC BY-NC-SA 4.0</li>
        <li><strong>Mango Leaf Disease:</strong> Licensed under CC BY-NC 4.0</li>
      </ul>
      <p class="license-statement">CropCheckUp derived dataset and bundled model artifacts are licensed CC BY-NC-SA 4.0 for non-commercial use.</p>
    </div>
  </div>
</section>

<style>
  .section-header {
    max-width: 820px;
    margin-bottom: var(--space-2xl);
  }

  .section-kicker {
    margin: 0 0 var(--space-s);
    color: var(--color-brand-secondary);
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }
  
  .section-subtitle {
    margin: 0;
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-l);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: var(--color-bg-raised);
  }

  .resource-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-glass);
  }

  .resource-icon {
    margin-bottom: var(--space-m);
    position: relative;
    z-index: 1;
    color: var(--color-brand-primary);
  }
  
  .resource-content {
    flex: 1;
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-l);
  }

  .resource-content h3 {
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-s);
  }

  .resource-content p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin: 0;
  }

  .resource-list {
    display: grid;
    gap: var(--space-s);
    margin: var(--space-l) 0 0;
    padding: 0;
    list-style: none;
  }

  .resource-list li {
    display: flex;
    gap: var(--space-s);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.4;
  }

  .resource-list li::before {
    content: '';
    flex: 0 0 auto;
    width: 8px;
    height: 8px;
    margin-top: 0.45rem;
    border-radius: 50%;
    background: var(--color-brand-secondary);
  }

  .resource-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-m);
    border-top: 1px solid var(--color-border-subtle);
    position: relative;
    z-index: 1;
  }

  .action-text {
    font-weight: 500;
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    transition: color 0.3s ease;
  }

  .arrow {
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  .resource-card:hover .action-text {
    color: var(--color-brand-primary);
  }

  .resource-card:hover .arrow {
    color: var(--color-brand-primary);
    transform: translateX(5px);
  }

  .dataset-attribution {
    margin-top: var(--space-xl);
    padding: var(--space-l);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
  }

  .dataset-attribution h3 {
    margin-top: 0;
    margin-bottom: var(--space-s);
    font-size: var(--font-size-md);
    color: var(--color-text-primary);
  }

  .dataset-attribution ul {
    margin: 0 0 var(--space-m) 0;
    padding-left: var(--space-l);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
  }

  .license-statement {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    font-weight: 500;
  }
</style>
