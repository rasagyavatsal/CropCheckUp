---
import packageJson from '../../package.json';

const landingVersion = packageJson.version;
---
<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-top">
      <div class="footer-info">
        <div class="logo">
          <img src="/logo.png" width="24" height="24" alt="" class="logo-icon" aria-hidden="true" />
          <span class="logo-text">Crop<span class="text-highlight">CheckUp</span></span>
        </div>
        <p class="description">AI-assisted plant disease detection. Built for single-leaf image analysis with background removal, model-ready preprocessing, and on-device inference.</p>
      </div>
      
      <div class="footer-nav-groups">
        <div class="nav-group">
          <h4>Project</h4>
          <a href="#how-it-works">How It Works</a>
          <a href="#pipeline">Pipeline</a>
          <a href="#model-output">Model Output</a>
          <a href="#limitations">Limitations</a>
        </div>
        
        <div class="nav-group">
          <h4>Resources</h4>
          <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" target="_blank" rel="noopener noreferrer">Kaggle Notebook</a>
          <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" target="_blank" rel="noopener noreferrer">Dataset</a>
          <a href="https://github.com/rasagyavatsal/CropCheckUp" target="_blank" rel="noopener noreferrer">GitHub Repo</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">© {new Date().getFullYear()} CropCheckUp.</p>
      <p class="version">Landing v{landingVersion}</p>
      <p class="license-summary">
        <a href="https://github.com/rasagyavatsal/CropCheckUp/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">Code: Apache-2.0</a>. 
        <a href="https://github.com/rasagyavatsal/CropCheckUp/blob/main/DATASET_LICENSE.md" target="_blank" rel="noopener noreferrer">Model/data: CC-BY-NC-SA-4.0 non-commercial</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background-color: var(--color-bg-base);
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    overflow: hidden;
  }

  .footer-container {
    position: relative;
    z-index: 1;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-info {
    max-width: 400px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-m);
  }

  .logo-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .footer-nav-groups {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xl);
  }

  .nav-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .nav-group h4 {
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-s);
    font-family: var(--font-display);
  }

  .nav-group a {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-group a:hover {
    color: var(--color-brand-primary);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .copyright {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .version {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    margin: var(--space-xs) 0 0;
  }

  .license-summary {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    margin: var(--space-s) 0 0;
  }

  .license-summary a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .license-summary a:hover {
    color: var(--color-brand-primary);
    text-decoration: underline;
  }
</style>
