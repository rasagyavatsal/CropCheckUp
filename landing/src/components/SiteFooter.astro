---
<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-info">
      <div class="logo">CropCheckUp</div>
      <p class="description">AI-assisted plant disease detection.</p>
    </div>
    <div class="footer-links">
      <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" target="_blank" rel="noopener noreferrer">Kaggle Notebook</a>
      <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" target="_blank" rel="noopener noreferrer">Dataset</a>
      <a href="https://github.com/rasagyavatsal/CropCheckUp" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>
<style>
  .site-footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-subtle-border);
    padding-top: var(--space-l);
    padding-bottom: var(--space-l);
  }
  .footer-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    align-items: center;
    text-align: center;
  }
  .logo {
    font-weight: 700;
    font-size: var(--font-size-lg);
    color: var(--color-brand);
    margin-bottom: var(--space-xs);
  }
  .description {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
  }
  .footer-links {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    justify-content: center;
  }
  .footer-links a {
    color: var(--color-text-secondary);
    font-weight: 500;
    font-size: var(--font-size-sm);
  }
  .footer-links a:hover {
    color: var(--color-brand);
  }

  @media (min-width: 768px) {
    .footer-container {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
    .footer-info {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    .logo {
      margin-bottom: 0;
    }
  }
</style>
