---
---
<footer class="site-footer">
  <div class="footer-glow"></div>
  <div class="container footer-container">
    <div class="footer-top">
      <div class="footer-info">
        <div class="logo">
          <span class="logo-icon">🌿</span>
          <span class="logo-text">Crop<span class="text-gradient">CheckUp</span></span>
        </div>
        <p class="description">Empowering farmers and plant lovers with AI-assisted plant disease detection and actionable care guidance.</p>
      </div>
      
      <div class="footer-nav-groups">
        <div class="nav-group">
          <h4>Project</h4>
          <a href="#how-it-works">How It Works</a>
          <a href="#pipeline">Pipeline</a>
          <a href="#model-output">Model Output</a>
          <a href="#limitations">Limitations</a>
        </div>
        
        <div class="nav-group">
          <h4>Resources</h4>
          <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" target="_blank" rel="noopener noreferrer">Kaggle Notebook</a>
          <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" target="_blank" rel="noopener noreferrer">Dataset</a>
          <a href="https://github.com/rasagyavatsal/CropCheckUp" target="_blank" rel="noopener noreferrer">GitHub Repo</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">© {new Date().getFullYear()} CropCheckUp. Built with AI.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background-color: #020617; /* Darker than base */
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    overflow: hidden;
  }
  
  .footer-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 100px;
    background: radial-gradient(ellipse at bottom, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer-container {
    position: relative;
    z-index: 1;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-info {
    max-width: 400px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-m);
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .footer-nav-groups {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xl);
  }

  .nav-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .nav-group h4 {
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-s);
    font-family: var(--font-display);
  }

  .nav-group a {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-group a:hover {
    color: var(--color-brand-primary);
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .copyright {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin: 0;
  }
</style>
