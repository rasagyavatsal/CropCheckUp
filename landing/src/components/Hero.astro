---
import ProductVisual from './ProductVisual.astro';
---
<section id="hero" class="section hero">
  <div class="hero-bg-glow"></div>
  <div class="container hero-content">
    <div class="hero-text">
      <div class="badge glass-panel">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sparkle-icon"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        AI-Powered Plant Care
      </div>
      <h1 class="hero-title">
        Diagnose Crop Diseases with <span class="text-highlight">AI Precision</span>
      </h1>
      <p class="hero-description">
        CropCheckUp analyzes leaf images, removes backgrounds, and runs advanced machine learning to predict crop health. Get instant diagnosis and management guidance.
      </p>
      <div class="hero-ctas">
        <a href="https://www.kaggle.com/code/rasagyavatsal/cropcheckup" class="btn btn-primary cta-main">
          View Kaggle Notebook
        </a>
        <a href="https://www.kaggle.com/datasets/rasagyavatsal/cropcheckup-dataset" class="btn btn-outline cta-secondary">
          Explore Dataset
        </a>
      </div>
    </div>
    <div class="hero-visual-wrapper">
      <div class="visual-glow"></div>
      <ProductVisual />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  
  .hero-bg-glow {
    position: absolute;
    top: -10%;
    left: -10%;
    width: 50vw;
    height: 50vw;
    z-index: 0;
    pointer-events: none;
  }
  
  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  
  @media (min-width: 992px) {
    .hero-content {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-3xl);
    }
  }
  
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-brand-primary);
    margin-bottom: var(--space-l);
    border: 1px solid var(--color-border-hover);
  }
  
  .sparkle-icon {
    opacity: 0.8;
  }
  
  .hero-title {
    margin-bottom: var(--space-m);
    line-height: 1.1;
  }
  
  .hero-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    max-width: 600px;
    line-height: 1.8;
  }
  
  .hero-ctas {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
  }
  
  .cta-main, .cta-secondary {
    padding: 1rem 2rem;
    font-size: var(--font-size-lg);
  }
  
  .hero-visual-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .visual-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    filter: blur(40px);
    z-index: 0;
  }
  
  @media (max-width: 768px) {
    .hero-text {
      text-align: center;
    }
    
    .badge {
      margin: 0 auto var(--space-l);
    }
    
    .hero-description {
      margin: 0 auto var(--space-xl);
    }
    
    .hero-ctas {
      justify-content: center;
    }
  }
</style>
