---
---
<div class="mobile-frame glass-panel">
  <div class="mobile-notch"></div>
  <div class="video-container">
    <!-- Replace src with your actual video path, e.g., src="/demo-video.mp4" -->
    <video 
      class="app-video"
      autoplay 
      loop 
      muted 
      playsinline 
    >
      <source src="" type="video/mp4" />
    </video>
    
    <!-- This fallback text is visible when no video is loaded -->
    <div class="video-fallback">
      <div class="play-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <p>Video Placeholder</p>
      <p class="small-text">Add your video file in the src attribute</p>
    </div>
  </div>
</div>

<style>
  .mobile-frame {
    position: relative;
    width: 300px;
    height: 620px;
    flex-shrink: 0;
    margin: 0 auto;
    border-radius: 40px;
    padding: 10px;
    background: var(--color-bg-raised);
    border: 2px solid var(--color-border-subtle);
    box-shadow: 
      0 0 0 6px var(--color-border-hover),
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      inset 0 0 0 2px var(--color-border-subtle);
    z-index: 1;
    transform: perspective(1000px) rotateY(-10deg) rotateX(5deg);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-frame:hover {
    transform: perspective(1000px) rotateY(0) rotateX(0) translateY(-10px);
  }

  .mobile-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 25px;
    background: #000000;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    z-index: 10;
  }

  .video-container {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 30px;
    overflow: hidden;
    background: var(--color-bg-base);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: rgba(16, 185, 129, 0.1);
    position: relative;
    z-index: 2;
  }

  /* When the video has no source, it might not render over the fallback. 
     This ensures the fallback is visible beneath or over the blank video */
  .video-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-m);
    color: var(--color-text-secondary);
    pointer-events: none;
    z-index: 1;
  }

  .play-icon {
    color: var(--color-brand-primary);
    margin-bottom: var(--space-s);
    opacity: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-fallback p {
    margin: 0;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .small-text {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted) !important;
    margin-top: var(--space-xs) !important;
  }
</style>
