---
---
<div class="product-visual mobile-frame glass-panel">
  <div class="mobile-notch"></div>
  <div class="video-container">
    <video 
      class="app-video"
      autoplay 
      loop 
      muted 
      playsinline 
    >
      <source src="" type="video/mp4" />
    </video>
    
    <div class="video-fallback">
      <div class="scan-line"></div>
      <div class="fallback-header">
        <span class="status-dot"></span>
        CropCheckUp demo
      </div>
      <div class="play-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <p>Video Placeholder</p>
      <p class="small-text">Mobile walkthrough video slot</p>
    </div>
  </div>
</div>

<style>
  .mobile-frame {
    position: relative;
    width: 300px;
    height: 620px;
    flex-shrink: 0;
    margin: 0 auto;
    border-radius: 40px;
    padding: 10px;
    background: var(--color-bg-raised);
    border: 2px solid var(--color-border-subtle);
    box-shadow: 
      0 0 0 6px var(--color-border-hover),
      0 25px 50px -12px rgba(23, 32, 27, 0.34),
      inset 0 0 0 2px var(--color-border-subtle);
    z-index: 1;
    transform: perspective(1000px) rotateY(-10deg) rotateX(5deg);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-frame:hover {
    transform: perspective(1000px) rotateY(0) rotateX(0) translateY(-10px);
  }

  .mobile-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 25px;
    background: #000000;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    z-index: 10;
  }

  .video-container {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 30px;
    overflow: hidden;
    background:
      linear-gradient(var(--color-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid-line) 1px, transparent 1px),
      var(--color-bg-field);
    background-size: 28px 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: rgba(31, 122, 77, 0.08);
    position: relative;
    z-index: 2;
  }

  .video-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-m);
    color: var(--color-text-secondary);
    pointer-events: none;
    z-index: 3;
  }

  .scan-line {
    position: absolute;
    left: 24px;
    right: 24px;
    top: 24%;
    height: 2px;
    background: var(--color-brand-primary);
    box-shadow: 0 0 18px var(--color-brand-primary);
    opacity: 0.78;
    animation: scanPlaceholder 2.8s infinite ease-in-out;
  }

  @keyframes scanPlaceholder {
    0%, 100% { transform: translateY(-74px); opacity: 0; }
    18%, 82% { opacity: 0.78; }
    50% { transform: translateY(150px); }
  }

  .fallback-header {
    position: absolute;
    top: 58px;
    left: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-s);
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: var(--font-size-sm);
    font-weight: 700;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 12px var(--color-success);
  }

  .play-icon {
    color: var(--color-brand-primary);
    margin-bottom: var(--space-s);
    opacity: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-fallback p {
    margin: 0;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .small-text {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted) !important;
    margin-top: var(--space-xs) !important;
  }

  @media (max-width: 480px) {
    .mobile-frame {
      width: min(280px, 88vw);
      height: min(580px, 132vw);
      transform: perspective(1000px) rotateY(-6deg) rotateX(4deg);
    }
  }
</style>
