---
<section id="limitations" class="section">
  <div class="container">
    <div class="limitations-wrapper glass-panel">
      <div class="warning-icon">⚠️</div>
      <div class="limitations-content">
        <h2>Important Limitations</h2>
        <p class="intro-text">CropCheckUp is an AI-assisted screening tool. Results depend highly on image quality, lighting, leaf visibility, and whether the condition exists in the trained labels.</p>
        
        <div class="rules-grid">
          <div class="rule-item">
            <span class="rule-bullet">📸</span>
            <p>Use a clear image of one leaf, properly focused and well-lit.</p>
          </div>
          <div class="rule-item">
            <span class="rule-bullet">🚫</span>
            <p>Avoid blur, heavy shadows, and cluttered backgrounds with multiple plants.</p>
          </div>
          <div class="rule-item">
            <span class="rule-bullet">👨‍🔬</span>
            <p>Always confirm serious crop issues with a certified agriculture expert.</p>
          </div>
          <div class="rule-item">
            <span class="rule-bullet">🎯</span>
            <p>The app can only classify conditions within its supported 68-label dataset.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .limitations-wrapper {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl);
    border-left: 4px solid var(--color-warning);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .limitations-wrapper {
      flex-direction: row;
      gap: var(--space-xl);
      align-items: center;
    }
  }

  .limitations-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, rgba(245, 158, 11, 0.05) 0%, transparent 100%);
    pointer-events: none;
  }

  .warning-icon {
    font-size: 4rem;
    margin-bottom: var(--space-m);
    filter: drop-shadow(0 0 20px rgba(245, 158, 11, 0.3));
  }

  @media (min-width: 768px) {
    .warning-icon {
      margin-bottom: 0;
      font-size: 5rem;
    }
  }

  .limitations-content {
    flex: 1;
  }

  .limitations-content h2 {
    color: var(--color-warning);
    margin-bottom: var(--space-s);
  }

  .intro-text {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-xl);
    max-width: 800px;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-m);
  }

  @media (min-width: 768px) {
    .rules-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .rule-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-m);
    background: rgba(0, 0, 0, 0.2);
    padding: var(--space-m);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rule-bullet {
    font-size: var(--font-size-xl);
    margin-top: -2px;
  }

  .rule-item p {
    margin: 0;
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }
</style>
